---
import { locales, localeMeta, useTranslations, localizedPath, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
const home = localizedPath(locale, base);
const repo = 'https://github.com/AdnanHussainTurki/servicio';

const nav = [
  { href: '#features', label: t('nav.features') },
  { href: '#screenshots', label: t('nav.screenshots') },
  { href: '#architecture', label: t('nav.architecture') },
  { href: '#install', label: t('nav.install') },
];
---

<header class="hdr">
  <div class="wrap hdr-row">
    <a class="brand" href={home} aria-label="Servicio">
      <span class="brand-mark">S</span>
      <span class="brand-name">servicio</span>
      <span class="brand-sub">SUPERVISOR</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <div class="hdr-actions">
      <div class="lang" data-lang>
        <button class="lang-btn" aria-haspopup="listbox" aria-expanded="false" aria-label={t('a11y.lang')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>
          <span>{localeMeta[locale].name}</span>
        </button>
        <ul class="lang-menu" role="listbox">
          {locales.map((l) => (
            <li role="option" aria-selected={l === locale}>
              <a href={localizedPath(l, base)} lang={l} dir={localeMeta[l].dir} hreflang={l}>{localeMeta[l].name}</a>
            </li>
          ))}
        </ul>
      </div>

      <button class="theme-btn" data-theme-toggle aria-label={t('a11y.theme')}>
        <svg class="i-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg>
        <svg class="i-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <a class="btn btn-primary hdr-cta" href={repo}>{t('nav.github')}</a>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--line);
  }
  .hdr-row {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent), #ff9a4d);
    color: #1a0d03;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    box-shadow: var(--glow-accent);
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    color: var(--text-faint);
    align-self: center;
  }
  .nav {
    display: none;
    gap: 1.6rem;
    margin-inline-start: auto;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .nav a {
    transition: color 0.18s;
  }
  .nav a:hover {
    color: var(--text);
  }
  .hdr-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-inline-start: auto;
  }
  .nav + .hdr-actions {
    margin-inline-start: 1.6rem;
  }

  /* language dropdown */
  .lang {
    position: relative;
  }
  .lang-btn,
  .theme-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 38px;
    padding: 0 0.7rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line-strong);
    background: color-mix(in oklab, var(--panel) 60%, transparent);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    cursor: pointer;
    transition: color 0.18s, border-color 0.18s;
  }
  .theme-btn {
    width: 38px;
    justify-content: center;
    padding: 0;
  }
  .lang-btn:hover,
  .theme-btn:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .lang-menu {
    position: absolute;
    inset-inline-end: 0;
    top: calc(100% + 8px);
    min-width: 160px;
    margin: 0;
    padding: 6px;
    list-style: none;
    background: var(--panel);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
    display: none;
  }
  .lang[data-open] .lang-menu {
    display: block;
  }
  .lang-menu a {
    display: block;
    padding: 0.5rem 0.7rem;
    border-radius: 7px;
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  .lang-menu a:hover {
    background: var(--panel-2);
    color: var(--text);
  }
  .lang-menu [aria-selected='true'] a {
    color: var(--accent);
  }

  .i-moon {
    display: none;
  }
  [data-theme='light'] .i-sun {
    display: none;
  }
  [data-theme='light'] .i-moon {
    display: block;
  }

  .hdr-cta {
    display: none;
    padding: 0.55rem 0.95rem;
  }

  @media (min-width: 880px) {
    .nav {
      display: flex;
    }
    .hdr-cta {
      display: inline-flex;
    }
  }
</style>

<script is:inline>
  (() => {
    // theme toggle
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'light' ? 'dark' : 'light';
        root.dataset.theme = next;
        try {
          localStorage.setItem('servicio-theme', next);
        } catch (_) {}
      });
    });
    // language dropdown
    const lang = document.querySelector('[data-lang]');
    if (lang) {
      const btn = lang.querySelector('.lang-btn');
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = lang.toggleAttribute('data-open');
        btn.setAttribute('aria-expanded', String(open));
      });
      document.addEventListener('click', () => {
        lang.removeAttribute('data-open');
        btn.setAttribute('aria-expanded', 'false');
      });
    }
  })();
</script>
