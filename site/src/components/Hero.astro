---
import { useTranslations, localizedPath, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;
const img = `${base.replace(/\/$/, '')}/images/dashboard-dark.png`;
const repo = 'https://github.com/AdnanHussainTurki/servicio';
const releases = `${repo}/releases/latest`;
---

<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <p class="eyebrow load" style="--d:0ms">{t('hero.badge')}</p>
      <h1 class="hero-title load" style="--d:80ms">{t('hero.title')}</h1>
      <p class="hero-sub load" style="--d:160ms">{t('hero.subtitle')}</p>
      <div class="hero-cta load" style="--d:240ms">
        <a class="btn btn-primary" href={releases}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
          {t('hero.cta_download')}
        </a>
        <a class="btn btn-ghost" href={repo}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03a9.5 9.5 0 0 1 5 0c1.91-1.3 2.75-1.03 2.75-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z"/></svg>
          {t('hero.cta_github')}
        </a>
      </div>
      <p class="hero-note eyebrow load" style="--d:320ms">{t('hero.note')}</p>
    </div>

    <div class="hero-shot load" style="--d:280ms">
      <div class="frame">
        <div class="frame-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="frame-title">servicio — supervisor</span>
        </div>
        <img
          src={img}
          width="1280"
          height="820"
          alt={t('showcase.shots.dashboard_dark')}
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="hud-chip chip-1"><span class="pulse"></span>4 running</div>
      <div class="hud-chip chip-2">64.6% cpu</div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(2.5rem, 1rem + 6vw, 5.5rem) clamp(2.5rem, 1rem + 5vw, 4.5rem);
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: 1.05fr 1.25fr;
    }
  }
  .hero-title {
    font-size: clamp(2.6rem, 1.3rem + 6vw, 4.7rem);
    font-weight: 800;
    margin-block: 1rem 1.1rem;
    background: linear-gradient(180deg, var(--text), color-mix(in oklab, var(--text) 55%, var(--text-faint)));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-sub {
    font-size: clamp(1.02rem, 0.9rem + 0.5vw, 1.22rem);
    color: var(--text-dim);
    max-width: 52ch;
    margin: 0;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-block: 1.8rem 1.1rem;
  }
  .hero-note {
    margin: 0;
  }

  /* Browser frame */
  .hero-shot {
    position: relative;
  }
  .frame {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--panel);
    box-shadow: var(--shadow);
    transform: perspective(1600px) rotateY(-7deg) rotateX(2deg);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-shot:hover .frame {
    transform: perspective(1600px) rotateY(-2deg) rotateX(0.5deg);
  }
  html[dir='rtl'] .frame {
    transform: perspective(1600px) rotateY(7deg) rotateX(2deg);
  }
  html[dir='rtl'] .hero-shot:hover .frame {
    transform: perspective(1600px) rotateY(2deg) rotateX(0.5deg);
  }
  .frame-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--panel-2) 80%, transparent);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .frame-bar .dot:first-child {
    background: var(--accent);
  }
  .frame-title {
    margin-inline-start: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
  }
  .frame img {
    width: 100%;
    height: auto;
  }

  .hud-chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--panel) 88%, transparent);
    border: 1px solid var(--line-strong);
    backdrop-filter: blur(10px);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text);
    box-shadow: var(--shadow);
    animation: float 5.5s ease-in-out infinite;
  }
  .chip-1 {
    inset-block-end: 12%;
    inset-inline-start: -18px;
  }
  .chip-2 {
    inset-block-start: 16%;
    inset-inline-end: -14px;
    animation-delay: -2.6s;
    color: var(--accent-2);
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--green) 70%, transparent);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--green) 60%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-9px); }
  }

  /* staggered load-in */
  .load {
    opacity: 0;
    transform: translateY(16px);
    animation: rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .load,
    .hud-chip {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
